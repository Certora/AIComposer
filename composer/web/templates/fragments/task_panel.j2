{# A task's drill-down panel — the right pane on the run page.

   Emitted once on task registration as an ``append`` to ``#panels``.
   The ``#log-{task_id}`` div is the EmitTree's root selector for this
   task; nested workflows and log entries land inside it.

   Only the ``.active`` panel is visible at a time (CSS-driven, toggled
   by the hash-routing script in run.html).

   ctx:
     task_id      — id of the task
     label        — human-readable task label
     phase_label  — human-readable phase label (subtitle)
#}
<section id="panel-{{ task_id }}" class="task-panel">
  <header class="task-panel-header">
    <h2>{{ label }}</h2>
    <span class="task-panel-phase">{{ phase_label }}</span>
  </header>
  <div id="log-{{ task_id }}" class="task-log"></div>
</section>
