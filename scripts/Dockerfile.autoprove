# syntax=docker/dockerfile:1.7
#
# Container for the AI Composer auto-prove (console mode) execution path.
#
# Build (BuildKit required — uses --mount=type=ssh to clone private Certora repos):
#   DOCKER_BUILDKIT=1 docker buildx build --ssh default \
#       -t aicomposer-autoprove -f scripts/Dockerfile.autoprove .
#
# Or via compose:
#   docker compose -f scripts/docker-compose.yml --profile autoprove build
#
# Cloud prover only — the container does not bundle a local prover build.
# CERTORAKEY must be supplied at runtime.

# ---- Stage 1: build prover documentation HTML for the RAG DB ----
FROM python:3.12-slim AS docs-builder

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update \
 && apt-get install -y --no-install-recommends git ca-certificates openssh-client \
 && rm -rf /var/lib/apt/lists/* \
 && mkdir -p -m 0700 /root/.ssh \
 && ssh-keyscan github.com >> /root/.ssh/known_hosts

WORKDIR /build
RUN --mount=type=ssh \
    git clone --depth 1 git@github.com:Certora/Documentation.git docs

RUN python -m venv /venv \
 && /venv/bin/pip install --no-cache-dir -r /build/docs/requirements.txt

RUN set -eux; \
    mkdir -p /out; \
    for target in /build/docs/docs/cvl /build/docs/docs/solana /build/docs/docs/prover /build/docs/docs/user-guide; do \
      cp /build/docs/conf.py "$target/"; \
      ( cd "$target" && /venv/bin/sphinx-build -M singlehtml . tmp ); \
      cp "$target/tmp/singlehtml/index.html" "/out/$(basename "$target").html"; \
    done

# ---- Stage 2: final runtime image ----
FROM python:3.12-slim AS final

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    AUTOPROVE_HOME=/opt/autoprove \
    VIRTUAL_ENV=/opt/autoprove/venv \
    PATH=/opt/autoprove/venv/bin:/usr/local/bin:/usr/bin:/bin \
    HOME=/opt/autoprove/home \
    HF_HOME=/opt/autoprove/home/.cache/huggingface \
    UV_CACHE_DIR=/tmp/uv-cache

# Pre-create a shared HOME under /opt/autoprove. The compose service runs the
# container as the host user (so bind-mounted /work files are owned by the
# host user, not root), but the image still bakes caches like the HF model
# and solc-select. HOME and its read-only caches stay at 0755 (world-readable,
# not world-writable) — SSH client rejects a world-writable HOME and would
# refuse to use ~/.ssh during git clones below. Anything that needs writing
# at runtime (uv's cache) is redirected to /tmp via UV_CACHE_DIR.
RUN mkdir -p $HOME/.cache/huggingface $HOME/.solc-select \
 && chmod -R go+rX $HOME

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      git ca-certificates openssh-client \
      build-essential libffi-dev \
      curl \
 && rm -rf /var/lib/apt/lists/* \
 && mkdir -p -m 0700 /root/.ssh \
 && ssh-keyscan github.com >> /root/.ssh/known_hosts
# known_hosts intentionally goes to /root/.ssh, NOT $HOME/.ssh: openssh's
# ssh client ignores HOME and uses getpwuid() to find the home dir, so it
# looks at /root/.ssh during the root-owned build regardless of our
# ENV HOME=/opt/autoprove/home setting. SSH is build-time only — at runtime
# (as the host user) we never need ~/.ssh/known_hosts.

# uv is needed by populate_rag.sh (uv run --group ragbuild) and the README's
# kb_populate.py invocation. Install it once into a stable location.
RUN curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR=/usr/local/bin sh

# Java 21 (Temurin JRE) — certora_cli uses it for local CVL spec syntax
# checking before uploading to the cloud. Without it the prover prints
# "WARNING: `java` is not installed". Debian Bookworm only ships openjdk-17,
# and we need >= 19, so install via the Adoptium apt repo.
# python:3.12-slim does not include gnupg by default — install it transiently
# alongside the key import, then remove.
RUN apt-get update \
 && apt-get install -y --no-install-recommends gnupg \
 && mkdir -p /etc/apt/keyrings \
 && curl -fsSL https://packages.adoptium.net/artifactory/api/gpg/key/public \
      | gpg --dearmor -o /etc/apt/keyrings/adoptium.gpg \
 && echo "deb [signed-by=/etc/apt/keyrings/adoptium.gpg] https://packages.adoptium.net/artifactory/deb $(. /etc/os-release && echo $VERSION_CODENAME) main" \
      > /etc/apt/sources.list.d/adoptium.list \
 && apt-get update \
 && apt-get install -y --no-install-recommends temurin-21-jre \
 && apt-get purge -y gnupg \
 && apt-get autoremove -y \
 && rm -rf /var/lib/apt/lists/*

WORKDIR $AUTOPROVE_HOME

# Clone the private companion repos via the forwarded SSH agent. PreAudit
# is left at its default tip here on purpose — see the install step below.
ARG PREAUDIT_COMMIT=b941b4147d30fa460e2f9a593b1c8517e7e62eee
RUN --mount=type=ssh \
    git clone --depth 1 git@github.com:Certora/Autosetup.git Autosetup \
 && git clone git@github.com:Certora/PreAudit.git PreAudit

# Bake the AI Composer source (build context = repo root).
COPY . $AUTOPROVE_HOME/AIComposer

# Build the venv. The install order mirrors scripts/autoprover-setup.sh:
# Autosetup first, then PreAudit. Autosetup's pyproject pins everything we
# need at compatible versions — ai-composer (with [ml]), prover-output-utility
# at the commit that exposes JobReport, certora dependencies — so we lean on
# its dep resolution rather than fighting pip with manual pins.
RUN python -m venv $VIRTUAL_ENV \
 && pip install --upgrade pip wheel setuptools

RUN --mount=type=ssh \
    pip install -e "$AUTOPROVE_HOME/Autosetup"

# Install PreAudit at the freshly cloned tip and only THEN check out the
# pinned commit. The pinned tree's pyproject references prover-output-utility
# via a `github.com-pou` SSH alias the container doesn't have, which causes
# a flaky `ssh: Could not resolve hostname github.com-pou` during pip install;
# at tip pip sees the package already satisfied by Autosetup and skips it.
# Same order as scripts/autoprover-setup.sh.
RUN --mount=type=ssh \
    pip install -e "$AUTOPROVE_HOME/PreAudit" \
 && ( cd "$AUTOPROVE_HOME/PreAudit" && git checkout "$PREAUDIT_COMMIT" )

# Autosetup pulls `ai-composer[ml]` transitively, which covers sentence-
# transformers / einops, but not the [prover] extra (certora_cli). Add it.
RUN pip install certora_cli

# Replace the transitively-installed ai-composer (from autosetup's URL pin)
# with our baked editable source so local source changes take effect.
# --no-deps so pip doesn't re-resolve and churn prover-output-utility.
RUN pip install --no-deps -e "$AUTOPROVE_HOME/AIComposer"

# Pre-download the sentence-transformers embedding model so containers can
# start offline-fast. Without this every run re-fetches ~500MB into the
# ephemeral container's HF cache. trust_remote_code is required because
# nomic-embed-text-v1.5 ships custom modeling code in its HF repo.
# HF_HOME points the cache at /opt/autoprove/home/.cache/huggingface (set in
# the ENV block above), which is world-readable so any UID at runtime can
# load it. Then chmod the cache subtree world-writable so the HF library
# can drop `.no_exist` marker files at runtime (it logs noisy "Permission
# denied" warnings if it can't — non-fatal, but ugly).
RUN python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('nomic-ai/nomic-embed-text-v1.5', trust_remote_code=True)" \
 && chmod -R go+rwX $HF_HOME

# Solidity compiler. The pipeline (and the LLM prompts) call solc by the
# `solcX.Y` naming convention. Skip solc-select entirely — its install
# location is governed by pwd.getpwuid(uid).pw_dir rather than $HOME, which
# makes its state invisible to non-root runtime users. Just download the
# static linux binary and drop it on PATH under the expected name. (Also
# expose it as plain `solc` for tools that look for that.)
RUN curl -fsSL https://github.com/ethereum/solidity/releases/download/v0.8.29/solc-static-linux \
        -o /usr/local/bin/solc8.29 \
 && chmod 0755 /usr/local/bin/solc8.29 \
 && ln -sf /usr/local/bin/solc8.29 /usr/local/bin/solc

# Pre-built CVL/prover HTML — populate_rag.sh looks here.
COPY --from=docs-builder /out/ $AUTOPROVE_HOME/AIComposer/scripts/prover-docs/

# Trim build tooling now that wheels are installed.
RUN apt-get purge -y build-essential libffi-dev curl \
 && apt-get autoremove -y \
 && rm -rf /var/lib/apt/lists/*

# These match autoprover-setup.sh exports. Database host/port assume the
# compose-managed postgres service; override per-run if needed.
ENV AUTOSETUP_PATH=$AUTOPROVE_HOME/Autosetup \
    PREAUDIT_PATH=$AUTOPROVE_HOME/PreAudit \
    CERTORA_AI_COMPOSER_PGHOST=postgres \
    CERTORA_AI_COMPOSER_PGPORT=5432

COPY scripts/autoprove-entrypoint.sh /usr/local/bin/autoprove-entrypoint
RUN chmod +x /usr/local/bin/autoprove-entrypoint

# Make every baked thing under /opt/autoprove world-readable so the runtime
# user (host UID supplied by compose) can read source, venv, solc-select
# binaries, and the HF model cache.
#
# Also make /etc/passwd and /etc/group world-writable so the entrypoint can
# append a synthetic entry for whatever host UID the container runs as.
# Without that entry, libraries that call pwd.getpwuid() (e.g. torch's
# cache_dir_utils via getpass.getuser()) crash on `KeyError: 'getpwuid(): uid
# not found: <UID>'`. This chmod is done LAST because earlier apt-get
# operations (notably the Temurin JRE install, which creates a system group)
# rewrite /etc/passwd or /etc/group and reset their permissions to 0644.
RUN chmod -R go+rX $AUTOPROVE_HOME \
 && chmod 0666 /etc/passwd /etc/group

WORKDIR /work

ENTRYPOINT ["/usr/local/bin/autoprove-entrypoint"]
CMD ["console-autoprove", "--help"]
