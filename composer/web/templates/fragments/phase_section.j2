{# A phase section in the summary aside.

   Emitted as an ``append`` to ``#summary`` the first time a task in
   ``phase`` registers. Subsequent task registrations under the same
   phase append to ``#rows-{phase_id}``.

   ctx:
     phase_id     — slug for ids (e.g. "BUG_ANALYSIS")
     phase_label  — human-readable label
#}
<details id="phase-{{ phase_id }}" class="phase-section" open>
  <summary class="phase-summary">{{ phase_label }}</summary>
  <ul id="rows-{{ phase_id }}" class="task-rows"></ul>
</details>
